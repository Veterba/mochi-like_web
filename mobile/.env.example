# URL the app uses to reach the backend API.
#
# The backend listens on port 4200 by default (backend/.env PORT).
# On a real phone "localhost" is the phone itself — use your computer's LAN IP
# (find it with `ip addr` / `ipconfig`; phone and computer must be on the same
# Wi-Fi network).
#
# IMPORTANT: EXPO_PUBLIC_* vars are baked into the JS bundle at build time.
# After changing this file, restart the dev server with:  npx expo start -c
EXPO_PUBLIC_API_URL=http://192.168.x.x:4200/api

# Existing config
CONNECTION_STRING=postgres://...your supabase connection string...
JWT_SECRET=change-me
PORT=4200

# LLM provider (any OpenAI-compatible API)
# --- OpenRouter (free Qwen models): https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.6-27b:free
# --- Google AI Studio alternative: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-key-here

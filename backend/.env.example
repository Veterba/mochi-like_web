# Existing config
CONNECTION_STRING=postgres://...your supabase connection string...
JWT_SECRET=change-me
PORT=4200

# Email (Resend) — verification codes. If RESEND_API_KEY is unset, the code is
# logged to the server console instead of emailed (fine for local dev).
# MAIL_FROM must be on a domain you've verified in Resend to reach any recipient;
# the default sandbox sender only delivers to your own Resend account email.
RESEND_API_KEY=
MAIL_FROM=Pop Up <noreply@yourdomain.com>

# LLM provider (any OpenAI-compatible API)
# --- OpenRouter (free Qwen models): https://openrouter.ai/keys
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# --- Google AI Studio alternative: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-key-here
